# Variables de ejemplo.
# Copiar este archivo SOLO en el servidor a una ruta privada fuera del repositorio
# y exportar PORTAL_ENV_FILE apuntando a ese archivo.

# Portal Settings
SECRET_KEY=REEMPLAZAR_EN_SERVIDOR
DEBUG=False
ALLOWED_HOSTS=api.notariamendoza.com
USE_X_FORWARDED_HOST=True
USE_X_FORWARDED_PROTO=True
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# Portal Database (PostgreSQL)
DB_NAME=portal_cliente
DB_USER=portal_user
DB_PASSWORD=REEMPLAZAR_EN_SERVIDOR
DB_HOST=127.0.0.1
DB_PORT=5432
DB_CONN_MAX_AGE=60
DB_SSLMODE=prefer

# SIGNO Database (MariaDB - Read Only via PyMySQL)
SIGNO_DB_NAME=notarios
SIGNO_DB_USER=bkssigno
SIGNO_DB_PASSWORD=REEMPLAZAR_EN_SERVIDOR
SIGNO_DB_HOST=127.0.0.1
SIGNO_DB_PORT=3306

# Redis (for Celery)
REDIS_URL=redis://localhost:6379/0

# Frontend origins permitidos
FRONTEND_BASE_URL=https://notariamendoza.com/portal
CORS_ALLOWED_ORIGINS=https://notariamendoza.com
CSRF_TRUSTED_ORIGINS=https://notariamendoza.com,https://api.notariamendoza.com
PORTAL_DATA_SOURCE=mirror

# Throttling
THROTTLE_LOGIN=5/minute
THROTTLE_FORGOT_PASSWORD=3/hour
THROTTLE_RESET_PASSWORD=5/hour
THROTTLE_TOKEN_REFRESH=10/minute
THROTTLE_LOGOUT=20/minute

# Waitress
WAITRESS_THREADS=8
WAITRESS_CONNECTION_LIMIT=100
WAITRESS_CLEANUP_INTERVAL=30
WAITRESS_CHANNEL_TIMEOUT=120

# Email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.office365.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=legal@notariamendoza.com
EMAIL_HOST_PASSWORD=REEMPLAZAR_EN_SERVIDOR
